# Assembly .gitignore for AVRA Compilator, Microchip Studio, and SimulIDE

# --- AVRA Compilator ---
# AVRA typically generates .hex, .obj, .eep, .lst, .map, .cof, .sym, .bin files
*.hex
*.obj
*.eep
*.lst
*.map
*.cof
*.sym
*.bin

# --- Microchip Studio ---
# Microchip Studio creates various output and build files
# Ignore build and debug folders
[Bb]uild/
[Dd]ebug/
[Rr]elease/
*.elf
*.cof
*.map
*.lss
*.eep
*.hex
*.log
*.d
*.o
*.obj
*.sdf
*.aps
*.dep
*.db
*.suo
*.user
*.ipch
*.opensdf
*.plg
*.vsp
*.ncb

# Visual Studio 2015/2017 cache/options directory
.vs/

# Microchip Studio project temporary files
*.bak
*.tmp

# --- SimulIDE ---
# SimulIDE saves simulation files and temporary files
*.sim
*.simbackup
*.tmp

# General OS/IDE/Editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*.swn
*.bak
*.tmp
*.~*

# Ignore any compiled output or binary files
*.exe
*.out

# Ignore log files
*.log

# Ignore hidden files starting with a dot, except .gitignore
!.gitignore
.*~